{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.example.test/schemas/rest/health.schema.json",
  "title": "HealthResponse",
  "type": "object",
  "required": ["status", "service", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "degraded", "down"]
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
