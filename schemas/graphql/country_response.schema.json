{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.example.test/schemas/graphql/country_response.schema.json",
  "title": "CountryGraphQLResponse",
  "type": "object",
  "required": ["data"],
  "additionalProperties": true,
  "properties": {
    "data": {
      "type": "object",
      "required": ["country"],
      "additionalProperties": true,
      "properties": {
        "country": {
          "type": "object",
          "required": ["code", "name"],
          "additionalProperties": true,
          "properties": {
            "code": {"type": "string", "minLength": 2, "maxLength": 3},
            "name": {"type": "string", "minLength": 1},
            "emoji": {"type": "string"},
            "currency": {"type": ["string", "null"]}
          }
        }
      }
    },
    "errors": {
      "type": "array"
    }
  }
}
